But this has a draw back becuase in the worksheet if we make any change the data will change
so we need only the drop doen limited data to change

Private Sub Worksheet_Change(ByVal Target As Range)
If Target.Address = "$B$5" Then
    Range("B19:J849").AdvancedFilter Action:=xlFilterInPlace, CriteriaRange:= _
        Range("L5:L6"), Unique:=False
End If
        
End Sub


